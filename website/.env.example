# Ask Clive (website) — Vercel environment variables
# Add these in Vercel → Project → Settings → Environment Variables

# Required — Claude API for public Ask Clive replies
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-4-6
# CLIVE_MODEL=

# Recommended — live approved Context Items from AstraJax base (read-only PAT)
# Without this, Clive uses bundled fallback context baked into the site.
AIRTABLE_READ_TOKEN=

# Journey timeline clips (Vercel Blob). Set to the Blob folder URL after running
# scripts/upload-journey-clips-to-blob.mjs, e.g.
# https://<store>.public.blob.vercel-storage.com/journey-clips/talk
# Leave unset locally to play clips from the /public folder.
NEXT_PUBLIC_JOURNEY_CLIPS_BASE=

# Write token for the upload script only (not used by the site at runtime).
# From Vercel → Storage → your Blob store → tokens, or `vercel env pull`.
# BLOB_READ_WRITE_TOKEN=
