# Ask Clive (website) — Vercel environment variables
# Add these in Vercel → Project → Settings → Environment Variables

# Required — Claude API for public Ask Clive replies
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-4-6
# CLIVE_MODEL=

# Recommended — live approved Context Items from AstraJax base (read-only PAT)
# Without this, Clive uses bundled fallback context baked into the site.
AIRTABLE_READ_TOKEN=

# Journey timeline clips (Vercel Blob, private store). After running
# scripts/upload-journey-clips-to-blob.mjs, set on Vercel (Production + Preview):
#   NEXT_PUBLIC_JOURNEY_CLIPS_BASE=/api/journey-clips
# BLOB_READ_WRITE_TOKEN is auto-provisioned when Blob is linked to the project.
# Leave NEXT_PUBLIC_JOURNEY_CLIPS_BASE unset locally to play from /public.
NEXT_PUBLIC_JOURNEY_CLIPS_BASE=

# Write token for the upload script only (also in Vercel when Blob is linked).
# BLOB_READ_WRITE_TOKEN=
