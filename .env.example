# Clive Context Architecture V2 credentials
# Copy to .env and fill with separate Airtable PATs where possible.
# Do not commit .env. Do not put AIRTABLE_APPROVER_TOKEN in agent/MCP config.

# Read-only PAT for Curator reads and validation
AIRTABLE_READ_TOKEN=

# Write PAT for Intake (Context Intake) and Curator Proposed Context Items only
AIRTABLE_WRITE_TOKEN=

# Approver PAT or passphrase holder — Matthew only, not available to agents
AIRTABLE_APPROVER_TOKEN=
